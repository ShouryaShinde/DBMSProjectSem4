
<!DOCTYPE html>
<head>
  <title>Vehicle Service System</title>
  <link rel = "stylesheet" href="styles/main.css" >
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
  <div class="d-flex justify-content-center  align-items-center vh-100">
    <form class="d-grid gap-3" action="/login" method="POST"> 
      <i class="bi bi-tools fs-1 mb-3 text-primary"></i>
      <h1 class="h3 mb-3 fw-normal">Please sign in</h1>
      <div class="form-floating"> 
        <input type="email" name="email" class="form-control" id="floatingInput" 
          placeholder="name@example.com"> 
          <label for="floatingInput">Email address</label> 
      </div>
      <div class="form-floating"> 
        <input type="password" name="password" class="form-control" id="floatingPassword"
          placeholder="Password"> 
          <label for="floatingPassword">Password</label> 
      </div>
      <% if (errorMessage) { %>
        <p class="text-danger"><%= errorMessage %></p>
      <% } %>
      <button class="btn btn-primary w-100 py-2" type="submit" name="action" value="SignIn">Sign in</button>
      <button class="btn btn-outline-primary w-100 py-2" type="submit" name="action" value="Register">Register</button>
      <p class="mt-5 mb-3 text-body-secondary">© 2026</p>
    </form>
  </div>
</body>
</html>
