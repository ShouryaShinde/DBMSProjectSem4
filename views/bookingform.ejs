<%- include("partials/header.ejs") %>

<form action="/book" method="POST" class="container mt-5 d-grid gap-4" style="max-width: 800px;">

  <h2 class="text-center mb-3">Book a Service</h2>

  <!-- Customer Details -->
  <div>
    <h5 class="mb-3">Customer Details</h5>
    <div class="row g-3">

      <div class="col-md-6 form-floating">
        <input type="text" name="firstName" class="form-control" id="firstName" placeholder="First Name" required>
        <label for="firstName">First Name</label>
      </div>

      <div class="col-md-6 form-floating">
        <input type="text" name="lastName" class="form-control" id="lastName" placeholder="Last Name" required>
        <label for="lastName">Last Name</label>
      </div>

      <div class="col-md-6 form-floating">
        <input type="tel" name="phone" class="form-control" id="phone" placeholder="Phone Number" required>
        <label for="phone">Phone Number</label>
      </div>

      <div class="col-md-6 form-floating">
        <input type="email" name="email" class="form-control" id="email" placeholder="Email" required>
        <label for="email">Email</label>
      </div>

    </div>
  </div>

  <!-- Vehicle Details -->
  <div>
    <h5 class="mb-3">Vehicle Details</h5>
    <div class="row g-3">

      <div class="col-md-6 form-floating">
        <input type="text" name="plateNo" class="form-control" id="vid" placeholder="Vehicle ID" required>
        <label for="plateNo">License Plate No.</label>
      </div>

      <div class="col-md-6 form-floating">
        <select name="vehicleType" class="form-select" id="vehicleType" required>
          <option value="">Select Type</option>
          <option value="2">2 Wheeler</option>
          <option value="4">4 Wheeler</option>
          <option value="6">6 Wheeler</option>
        </select>
        <label for="vehicleType">Vehicle Type</label>
      </div>

      <div class="col-md-6 form-floating">
        <select name="weightClass" class="form-select" id="weightClass" required>
          <option value="">Select Class</option>
          <option value="light">Light Vehicle</option>
          <option value="medium">Medium Vehicle</option>
          <option value="heavy">Heavy Vehicle</option>
        </select>
        <label for="weightClass">Weight Class</label>
      </div>

      <div class="col-md-6 form-floating">
        <input type="date" name="returnDate" class="form-control" id="returnDate" required>
        <label for="returnDate">Expected Return Date</label>
      </div>

    </div>
  </div>

  <!-- Service Details -->
  <div>
    <h5 class="mb-3">Service Details</h5>
    <div class="row g-3">

      <div class="col-md-6 form-floating">
        <select name="serviceType" class="form-select" id="serviceType" required>
          <option value="">Select Service</option>
          <option value="oil">Oil Change</option>
          <option value="repair">Repair</option>
          <option value="inspection">Inspection</option>
          <option value="washing">Washing</option>
        </select>
        <label for="serviceType">Service Type</label>
      </div>

      <div class="col-md-6 form-floating">
        <select name="urgency" class="form-select" id="urgency">
          <option value="">Select Urgency</option>
          <option value="normal">Normal</option>
          <option value="urgent">Urgent</option>
        </select>
        <label for="urgency">Urgency</label>
      </div>

      <div class="col-12 form-floating">
        <textarea name="description" class="form-control" placeholder="Describe issue" id="description" style="height: 100px"></textarea>
        <label for="description">Problem Description</label>
      </div>

    </div>
  </div>

  <!-- Pickup Option -->
  <div>
    <h5 class="mb-3">Pickup Option</h5>

    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="pickup" name="pickup">
      <label class="form-check-label" for="pickup">
        Request Vehicle Pickup
      </label>
    </div>

    <div class="form-floating mt-3">
      <input type="text" name="address" class="form-control" id="address" placeholder="Pickup Address">
      <label for="address">Pickup Address (if applicable)</label>
    </div>
  </div>

  <!-- Submit -->
  <button type="submit" class="btn btn-primary btn-lg w-100">
    Book Service
  </button>

</form>

<%- include("partials/footer.ejs") %>